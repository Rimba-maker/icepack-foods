---
const produkDropdown = [
  'Dimsum',
  'Bakso & Siomay',
  'Nugget & Sosis',
  'Seafood',
  'Ayam',
  'Sayuran',
  'Healthy Range',
  'Ready to Eat',
  'Dessert Frozen',
];
---

<header class="sticky top-0 z-50 h-20 border-b border-hairline bg-white">
  <nav class="mx-auto flex h-full max-w-[1280px] items-center justify-between px-6">
    <a href="/" class="text-lg font-semibold text-ink">IcePack Foods</a>

    <div class="hidden items-center gap-8 md:flex">
      <div class="group relative">
        <button class="text-sm font-semibold text-ink">Produk ▾</button>
        <div class="absolute left-0 top-full hidden w-56 rounded-b2c border border-hairline bg-white p-2 shadow-lg group-hover:block">
          {produkDropdown.map((item) => (
            <a href="/produk/" class="block rounded-sm px-3 py-2 text-sm text-body hover:bg-surface">{item}</a>
          ))}
        </div>
      </div>
      <a href="/supplier/" class="text-sm font-semibold text-ink">Supplier/B2B</a>
      <a href="/reseller/" class="text-sm font-semibold text-ink">Reseller</a>
      <a href="/resep/" class="text-sm font-semibold text-ink">Resep</a>
      <a href="/tentang/" class="text-sm font-semibold text-ink">Tentang</a>
    </div>

    <div class="flex items-center gap-3">
      <a
        href="/produk/"
        class="rounded-sm bg-primary px-5 py-3 text-sm font-medium text-white hover:bg-primary-active"
      >
        Order Sekarang
      </a>
      <a
        href="/supplier/"
        class="rounded-full bg-b2b px-5 py-3 text-sm font-medium text-white hover:bg-b2b-press"
      >
        Jadi Supplier
      </a>
    </div>
  </nav>
</header>
