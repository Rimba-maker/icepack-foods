---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Tentang IcePack Foods"
  description="Brand & supplier frozen food terpercaya — melayani dapur rumah dan dapur bisnis dengan standar cold chain, halal, dan higienis yang sama."
>
  <section class="px-6 py-16 md:px-20">
    <div class="mx-auto max-w-[1280px]">
      <h1 class="text-2xl font-bold text-ink md:text-3xl">Tentang IcePack Foods.</h1>
      <p class="mt-4 max-w-2xl text-body">
        IcePack Foods adalah pemain terbesar frozen food di kota, dipercaya ibu rumah tangga, anak
        kos & profesional, hingga restoran, hotel, dan catering. Konten lengkap menyusul.
      </p>
    </div>
  </section>
</Layout>
