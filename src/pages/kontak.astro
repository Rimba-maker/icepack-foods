---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Kontak | IcePack Foods"
  description="Hubungi IcePack Foods untuk order retail, konsultasi supplier B2B, atau pertanyaan lainnya."
>
  <section class="px-6 py-16 md:px-20">
    <div class="mx-auto max-w-[1280px]">
      <h1 class="text-2xl font-bold text-ink md:text-3xl">Hubungi Kami.</h1>
      <form class="mt-6 grid max-w-xl grid-cols-1 gap-4">
        <input class="rounded-input-b2b border border-hairline px-4 py-3 text-sm" placeholder="Nama" name="nama" />
        <input class="rounded-input-b2b border border-hairline px-4 py-3 text-sm" placeholder="WhatsApp / Email" name="kontak" />
        <textarea class="rounded-input-b2b border border-hairline px-4 py-3 text-sm" placeholder="Pesan" name="pesan" rows={4}></textarea>
        <button type="submit" class="rounded-sm bg-primary px-6 py-3 font-medium text-white hover:bg-primary-active">
          Kirim Pesan
        </button>
      </form>
    </div>
  </section>
</Layout>
